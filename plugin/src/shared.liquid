{% template main %}
<div class="layout" style="width: 100%; height: 100%;">
  {% if image_url %}
    <img class="image image-dither image--cover" src="{{ image_url }}" alt="{{ image_path }}">
  {% else %}
    <div class="layout layout--col gap--medium" style="flex: 1; align-items: center; justify-content: center;">
      <span class="title">No image available</span>
      <span class="description">Check your Nextcloud folder path.</span>
    </div>
  {% endif %}
</div>
{% unless view == 4 %}
<div class="title_bar">
  <span class="title">Nextcloud Image</span>
  <span class="instance">{{ image_path }}</span>
</div>
{% endunless %}
{% endtemplate %}
