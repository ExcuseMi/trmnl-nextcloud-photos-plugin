{% template main %}
{% liquid assign container_id = 'nc-image' | append_random %}

<div class="layout layout--stretch">
  {%- if image_url -%}
  <div class="flex flex--col flex--center">
    <div class="flex flex--center flex--grow" id="{{ container_id }}" style="overflow: hidden;">
      <img src="{{ image_url }}" class="image image-dither nc-image" alt="{{ image_path }}" />
    </div>
  </div>
  {%- else -%}
  <div class="flex flex--center">
    <div class="label">No images found.</div>
  </div>
  {%- endif -%}
</div>

<div class="title_bar">
  <span class="title">Nextcloud</span>
  <span class="instance">{{ image_path | split: '/' | last }}</span>
</div>

<script>
(function(global) {
  'use strict';

  var TRMNLImageLayout = {
    init: function(options) {
      var config = {
        containerId: options.containerId,
        imageSelector: options.imageSelector || '.nc-image',
        loadTimeout: options.loadTimeout || 5000,
        startDelay: options.startDelay || 100
      };

      var layoutImage = function() {
        var container = document.getElementById(config.containerId);
        if (!container) return;

        var parent = container.closest('.flex--col') || container.parentElement;
        if (!parent) return;

        var parentWidth = parent.offsetWidth;
        var parentHeight = parent.offsetHeight;

        if (parentWidth === 0 || parentHeight === 0) {
          setTimeout(layoutImage, 100);
          return;
        }

        container.style.display = 'flex';
        container.style.alignItems = 'center';
        container.style.justifyContent = 'center';
        container.style.width = '100%';

        var img = container.querySelector(config.imageSelector);
        if (!img) return;

        var applySize = function() {
          if (img.naturalWidth === 0 || img.naturalHeight === 0) return;

          var scale = Math.min(parentWidth / img.naturalWidth, parentHeight / img.naturalHeight, 1);
          img.style.width = Math.floor(img.naturalWidth * scale) + 'px';
          img.style.height = Math.floor(img.naturalHeight * scale) + 'px';
          img.style.objectFit = 'contain';
          img.style.display = 'block';
        };

        if (img.complete && img.naturalWidth > 0) {
          applySize();
        } else {
          var timeout = setTimeout(applySize, config.loadTimeout);
          img.onload = function() { clearTimeout(timeout); applySize(); };
          img.onerror = function() { clearTimeout(timeout); };
        }
      };

      var start = function() { setTimeout(layoutImage, config.startDelay); };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', start);
      } else {
        start();
      }
    }
  };

  global.TRMNLImageLayout = TRMNLImageLayout;
})(typeof window !== 'undefined' ? window : this);
</script>
<script>
  if (typeof TRMNLImageLayout !== 'undefined') {
    TRMNLImageLayout.init({
      containerId: '{{ container_id }}',
      imageSelector: '.nc-image',
      loadTimeout: 5000,
      startDelay: 100
    });
  }
</script>
{% endtemplate %}
