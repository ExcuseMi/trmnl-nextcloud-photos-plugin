{% template main %}
{% liquid
  assign canvas_mode = trmnl.plugin_settings.custom_fields_values.canvas_mode
  assign fields = trmnl.plugin_settings.custom_fields_values.metadata_fields

  assign has_meta = false
  if fields contains 'date' and meta.date_ts
    assign has_meta = true
  endif
  if fields contains 'camera' and meta.camera
    assign has_meta = true
  endif
  if fields contains 'exposure' and meta.exposure
    assign has_meta = true
  endif
  if fields contains 'focal' and meta.focal
    assign has_meta = true
  endif
  if fields contains 'dimensions' and meta.megapixels
    assign has_meta = true
  endif
  if fields contains 'filesize' and meta.file_size
    assign has_meta = true
  endif
  if fields contains 'filename' and meta.filename
    assign has_meta = true
  endif
  if fields contains 'folder' and meta.folder
    assign has_meta = true
  endif
  if fields contains 'gps' and meta.gps
    assign has_meta = true
  endif
  if fields contains 'count'
    assign has_meta = true
  endif
%}

<style>
  .nc-image-container img {
    height: 100%;
    object-fit: {% if canvas_mode == 'true' %}cover{% else %}contain{% endif %};
  }
  .nc-meta-overlay {
    position: absolute;
    bottom: 5px;
    left: 5px;
    background-color: black;
    width: auto !important;
    color: white;
    padding: 5px 20px;
    border-radius: 7px;
    z-index: 10;
  }
</style>

<div class="layout layout--stretch layout--center gap--none m--0 p--0 {{ image.bg_class }}" style="position: relative;">
  {% if image.url %}
    <div class="nc-image-container layout layout--col gap--space-between" style="height: 100%; width: 100%;">
      <img class="nc-image-file image-dither {% if canvas_mode == 'true' %}image--cover{% else %}image--contain{% endif %}" src="{{ image.url }}">
    </div>

    {% if has_meta %}
      <div class="grid nc-meta-overlay">
        <div class="col--span-1">
          <div class="item">
            <div class="content flex flex--col gap--none">
              {% if fields contains 'filename' and meta.filename %}
                <span class="label label--base lg:label--large text--white">{{ meta.filename }}</span>
              {% endif %}
              
              {% if fields contains 'folder' and meta.folder %}
                <span class="label label--small lg:label--base text--white opacity--80">{{ meta.folder }}</span>
              {% endif %}
              
              <div class="flex flex--col gap--none">
                {% if fields contains 'date' and meta.date_ts %}<span class="label label--small lg:label--base text--white">{{ meta.date_ts | date: "%b %-d, %Y" }}</span>{% endif %}
                {% if fields contains 'gps' and meta.gps %}<span class="label label--small lg:label--base text--white">{{ meta.gps }}</span>{% endif %}
                {% if fields contains 'camera' and meta.camera %}<span class="label label--small lg:label--base text--white">{{ meta.camera }}</span>{% endif %}
                {% if fields contains 'exposure' and meta.exposure %}<span class="label label--small lg:label--base text--white">{{ meta.exposure }}</span>{% endif %}
                {% if fields contains 'focal' and meta.focal %}<span class="label label--small lg:label--base text--white">{{ meta.focal }}</span>{% endif %}
                {% if fields contains 'dimensions' and meta.megapixels %}<span class="label label--small lg:label--base text--white">{{ meta.megapixels }}</span>{% endif %}
                {% if fields contains 'filesize' and meta.file_size %}<span class="label label--small lg:label--base text--white">{{ meta.file_size }}</span>{% endif %}
                {% if fields contains 'count' %}
                  {% if image.seq_position %}<span class="label label--small lg:label--base text--white">{{ image.seq_position }} / {{ image.folder_count }}</span>
                  {% else %}<span class="label label--small lg:label--base text--white">{{ image.folder_count }} photos</span>{% endif %}
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {% else %}
    <div class="layout layout--col flex--center gap--small" style="align-items: center; justify-content: center; height: 100%; width: 100%;">
      <span class="label label--small">Nextcloud Image</span>
      <span class="description text--center" data-clamp="4">{{ error | default: 'No images found.' }}</span>
    </div>
  {% endif %}
</div>
{% endtemplate %}
